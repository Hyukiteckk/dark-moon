# ── Sessão ────────────────────────────────────────────────────────────────────
SESSION_SECRET=gere_uma_string_aleatoria_longa

# ── Bot de aprovação Discord (Cloudflare Worker) ──────────────────────────────
# URL do Worker após o deploy: https://darkmoon-bot.<seu-subdominio>.workers.dev
BOT_SERVICE_URL=https://darkmoon-bot.SEU-SUBDOMINIO.workers.dev

# Chave secreta compartilhada — mesma configurada no Worker com:
#   wrangler secret put SECRET
BOT_SECRET=mesma_chave_do_worker
