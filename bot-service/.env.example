# ── Cloudflare Worker — Segredos (configure via wrangler secret put) ──────────
# wrangler secret put DISCORD_PUBLIC_KEY
DISCORD_PUBLIC_KEY=cole_a_public_key_aqui

# wrangler secret put DISCORD_BOT_TOKEN
DISCORD_BOT_TOKEN=Bot_cole_o_token_aqui

# wrangler secret put DISCORD_CHANNEL_ID
DISCORD_CHANNEL_ID=000000000000000000

# wrangler secret put SECRET
SECRET=gere_uma_chave_longa_aqui

# ── wrangler.toml — KV namespace ──────────────────────────────────────────────
# Crie o namespace e cole o ID em wrangler.toml:
#   wrangler kv namespace create DM_KV
