{
  "name": "discord-manager",
  "productName": "Discord Manager",
  "version": "1.0.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron desktop/main.cjs",
    "dev": "set ELECTRON_RUN_AS_NODE=&& electron desktop/main.cjs",
    "desktop": "set ELECTRON_RUN_AS_NODE=&& electron desktop/main.cjs",
    "build:win": "electron-builder --win --x64",
    "build:publish": "electron-builder --win --x64 --publish=always",
    "build:admin": "node scripts/build-admin.mjs",
    "build:membro": "node scripts/build-membro.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@discordjs/voice": "^0.16.1",
    "better-sqlite3": "^12.9.0",
    "cookie-session": "^2.0.0",
    "discord-rpc": "^4.0.1",
    "discord.js-selfbot-v13": "^3.7.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.6",
    "libsodium-wrappers": "^0.7.13",
    "opusscript": "^0.0.8"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.hyukiteckk.discordmanager",
    "productName": "Discord Manager",
    "copyright": "Hyukiteckk",
    "directories": {
      "output": "dist",
      "buildResources": "build-assets"
    },
    "icon": "build-assets/icon.ico",
    "files": [
      "**/*",
      "!{dist,docs,.devflow,.claude,build-assets}/**",
      "!{debug_*,read_cookies}.mjs",
      "!*.md",
      "!Iniciar.cmd",
      "!spyGateway.js"
    ],
    "extraResources": [
      {
        "from": "data/quest_helper.exe",
        "to": "quest_helper.exe"
      },
      {
        "from": "build-assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Discord Manager"
    },
    "portable": {
      "artifactName": "DiscordManager-portable-${arch}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Hyukiteckk",
      "repo": "Dark_Moon_Mission_Complete",
      "private": true
    }
  }
}
